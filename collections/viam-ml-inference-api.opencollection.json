{
  "opencollection": "1.0.0",
  "info": {
    "name": "Viam ML Inference API",
    "version": "2026.05"
  },
  "request": {
    "auth": {
      "type": "apikey",
      "key": "key",
      "value": "{{key}}",
      "placement": "header"
    }
  },
  "items": [
    {
      "info": {
        "name": "Inference",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Viam Get Inference",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://app.viam.com/viam.app.mlinference.v1.MLInferenceService/GetInference",
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Run inference against a registry-deployed model with binary input data."
        }
      ]
    }
  ],
  "bundled": true
}